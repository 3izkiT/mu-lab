generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id
  name          String
  email         String?         @unique
  passwordHash  String?
  credits       Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  analyses      Analysis[]
  purchases     Purchase[]
  subscriptions Subscription[]
  sessions      CheckoutSession[]
  tarotReadings TarotReading[]
  tarotUsages   TarotDailyUsage[]
}

model Analysis {
  id         String   @id
  userId     String
  summary    String
  deepInsight String
  career     Int
  wealth     Int
  love       Int
  birthDate  String?
  birthHour  String?
  birthSign  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Purchase {
  id          String   @id
  userId      String
  featureType String
  targetId    String?
  amountTHB   Int
  status      String   @default("completed")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, featureType])
  @@index([targetId])
}

model Subscription {
  id         String   @id
  userId     String
  planType   String
  status     String
  expiryDate DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiryDate])
}

model DataRequest {
  id          String   @id
  requestType String
  fullName    String
  email       String
  details     String
  status      String
  createdAt   DateTime @default(now())
}

model CheckoutSession {
  id           String   @id
  userId       String
  purchaseType String
  analysisId   String?
  amountTHB    Int
  status       String   @default("pending")
  provider     String
  providerRef  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model WebhookEvent {
  id        String   @id
  provider  String
  eventType String
  payload   String
  status    String
  createdAt DateTime @default(now())
}

/** สแนปช็อตบทความดูดวงรายวัน (ปฏิทินกรุงเทพฯ) สำหรับอ่านย้อนหลังและ URL ถาวร */
model DailyHoroscopeArchive {
  dateKey      String   @id
  headlineTh   String
  intro        String
  sectionsJson String
  forecastJson String
  source       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([updatedAt])
}

model TarotReading {
  id         String   @id
  userId     String
  dateKey    String
  question   String
  cardsJson  String
  preview    String
  deepInsight String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TarotDailyUsage {
  id        String   @id
  userId    String
  dateKey   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
}
