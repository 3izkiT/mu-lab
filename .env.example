# Canonical URL (SEO, sitemap, schema)
NEXT_PUBLIC_SITE_URL=https://example.com

# Gemini — พยากรณ์รายวัน + บทความดูดวงรายวัน
GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# Cron — ใช้กับ curl / GitHub Actions: Authorization: Bearer <CRON_SECRET>
# บน Vercel โปรเจกต์จะยิง /api/cron/daily-content อัตโนมัติด้วย header x-vercel-cron (ไม่บังคับตัวแปรนี้ แต่แนะนำไว้สำหรับทดสอบหรือ job ภายนอก)
CRON_SECRET=

# OAuth Login
# Callback:
#  - Google:   https://<your-domain>/api/auth/oauth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe webhook signing secret for production-safe verification
STRIPE_WEBHOOK_SECRET=

# Demo login (ควรปิดใน production)
# - ตั้งค่า NEXT_PUBLIC_ALLOW_DEMO_LOGIN=1 เพื่อโชว์ปุ่ม demo บนหน้า login
# - ตั้งค่า ALLOW_DEMO_LOGIN=1 เพื่ออนุญาต endpoint /api/auth/demo-login ทำงาน
NEXT_PUBLIC_ALLOW_DEMO_LOGIN=0
ALLOW_DEMO_LOGIN=0

# Database — Supabase Postgres (ใช้ pooler, IPv4)
# DATABASE_URL ใช้ Transaction pooler (port 6543) สำหรับ runtime ของ serverless
# DIRECT_URL ใช้ Session pooler (port 5432) สำหรับ prisma migrate (รองรับ DDL)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Sentry — error monitoring (เปล่าไว้ = no-op, ใส่เมื่อพร้อมเปิด)
# Public DSN ใช้กับ client bundle (NEXT_PUBLIC_) ส่วน SENTRY_DSN เผื่อ server แยก
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Google AdSense — เปล่าไว้ = ไม่โหลด script
NEXT_PUBLIC_ADSENSE_CLIENT=

# ข้อความแสดงบนหน้าแจ้งโอน/สลิป (หลายบรรทัดได้) — เลขบัญชีบริษัท / พร้อมเพย์ / คำแนะนำโอน
NEXT_PUBLIC_PAYMENT_INSTRUCTIONS="บริษัท xxx จำกัด\nธนาคาร … เลข …\nพร้อมเพย์ …"

# ถ้ามี URL ของ PSP จะพา user ไปจ่ายอัตโนมัติแทนหน้า slip
# PAYMENT_PROVIDER_CHECKOUT_URL=https://...
